# ── Required ──────────────────────────────────────────────────
API_ID=12345678
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here
OWNER_ID=your_telegram_user_id

# ── Optional ──────────────────────────────────────────────────
# Extra admin IDs (space-separated)
ADMINS=

# File size limit in MB (default 2048 = 2 GiB)
FILE_LIMIT_MB=2048

# Where to store downloaded files
DOWNLOAD_DIR=/tmp/zilong_dl

# Forward sent files to this channel (0 = disabled)
LOG_CHANNEL=0

# aria2c RPC (for torrents/magnets)
ARIA2_HOST=http://localhost
ARIA2_PORT=6800
ARIA2_SECRET=

# Google Drive service account JSON path
GDRIVE_SA_JSON=service_account.json

# ── Seedr (cloud torrent — free account) ───────────────────────────────────
SEEDR_USERNAME=
SEEDR_PASSWORD=

# SEEDR_PROXY — only needed when running on cloud IPs (Google Colab / Render /
# any Google Cloud / AWS IP).  Seedr blocks the add_torrent write operation for
# these IPs while read calls (list, fetch) still work fine.
#
#   HTTP proxy:   SEEDR_PROXY=http://user:pass@host:port
#   SOCKS5 proxy: SEEDR_PROXY=socks5://user:pass@host:port
#     → SOCKS5 requires: pip install httpx[socks]  (already in requirements.txt)
#
# Free proxy options:
#   • webshare.io      — 10 free residential proxies, no CC required
#   • proxyscrape.com  — free HTTP proxies (less reliable)
#   • SSH tunnel:  ssh -D 1080 user@yourserver  → socks5://localhost:1080
#
# Leave empty on a VPS / home server — no proxy needed there.
SEEDR_PROXY=
