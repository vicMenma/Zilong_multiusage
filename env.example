# ── Required ──────────────────────────────────────────────────
API_ID=12345678
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here
OWNER_ID=your_telegram_user_id

# ── Optional ──────────────────────────────────────────────────
# Extra admin IDs (space-separated)
ADMINS=

# File size limit in MB (default 2048 = 2 GiB)
FILE_LIMIT_MB=2048

# Where to store downloaded files
DOWNLOAD_DIR=/tmp/zilong_dl

# Forward sent files to this channel (0 = disabled)
LOG_CHANNEL=0

# aria2c RPC (for torrents/magnets)
ARIA2_HOST=http://localhost
ARIA2_PORT=6800
ARIA2_SECRET=

# Google Drive service account JSON path
GDRIVE_SA_JSON=service_account.json

# ── CloudConvert ───────────────────────────────────────────────
# API key for /hardsub and /ccstatus
# Get it at: cloudconvert.com/dashboard/api/v2/keys
CC_API_KEY=

# Optional: signing secret from CloudConvert webhook settings page
CC_WEBHOOK_SECRET=

# ── CloudConvert webhook URL ───────────────────────────────────
# Choose ONE of the two options below depending on your deployment:
#
# OPTION A — AWS EC2 / VPS with static public IP (recommended for servers)
#   1. Open port 8765 inbound TCP in your EC2 Security Group
#   2. Set WEBHOOK_BASE_URL to your public IP + port:
WEBHOOK_BASE_URL=
#   Example: WEBHOOK_BASE_URL=http://3.121.160.242:8765
#   The bot auto-registers this URL with CloudConvert on startup.
#   No ngrok needed.
#
# OPTION B — Colab / dynamic IP (uses ngrok tunnel)
#   Leave WEBHOOK_BASE_URL empty and set NGROK_TOKEN instead:
NGROK_TOKEN=
#   Get a free token at: ngrok.com → Your Authtoken
#
# NOTE: Even without a webhook URL, the ccstatus poller runs automatically
# and polls the CloudConvert API every 5 s to deliver completed jobs.
# Webhook just speeds up delivery from ~5s poll lag to near-instant.
